# Stage 1: Build React SPA
FROM node:20-slim AS forge-builder

WORKDIR /forge
COPY forge/package*.json ./
RUN npm ci
COPY forge/ .
RUN npm run build

# Stage 2: Python API
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Pull in the pre-built SPA from the node stage
COPY --from=forge-builder /forge/dist ./forge/dist

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
