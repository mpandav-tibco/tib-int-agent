# AgentForge React builder UI — Vite environment variables
# Copy this file to forge/.env and adjust as needed.

# Set to "true" to show the API key login screen immediately when no key is
# stored in the browser. Useful in production deployments where FORGE_API_KEY
# is set on the server. Leave "false" for open local dev (no login needed).
VITE_REQUIRE_AUTH=false
