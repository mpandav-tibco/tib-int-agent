# ── TARA environment variables ────────────────────────────────────────────────
# Copy this file to .env and fill in values for your environment.
# All variables have defaults that work for a local Ollama + Docker setup.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | groq | ollama-cloud | custom
LLM_PROVIDER=ollama

# Model name for the selected provider.
# ollama:     deepseek-r1:latest  llama3.1:8b  mistral:7b
# openai:     gpt-4o  gpt-4o-mini  gpt-3.5-turbo
# anthropic:  claude-opus-4-7  claude-sonnet-4-6  claude-haiku-4-5-20251001
# groq:       llama-3.3-70b-versatile  deepseek-r1-distill-llama-70b
LLM_MODEL=deepseek-r1:latest

# API key — leave blank for local Ollama.
LLM_API_KEY=

# Base URL — only needed for groq / ollama-cloud / custom providers.
LLM_API_BASE=

# ── Embedding model ───────────────────────────────────────────────────────────
# Must be available in Ollama (used for ingestion and KB search).
# Pull with: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# ── Ollama ────────────────────────────────────────────────────────────────────
# Leave as-is for local Ollama. Inside Docker use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Weaviate vector store ─────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080

# Name of the Weaviate collection that holds ingested KB chunks.
COLLECTION_NAME=TibcoKnowledge

# Path to local knowledge files ingested into Weaviate.
KNOWLEDGE_PATH=./data/knowledge

# ── Reranker ──────────────────────────────────────────────────────────────────
# Set to false to skip cross-encoder reranking (faster search, lower accuracy).
# Model (~85 MB) is auto-downloaded on first use when enabled.
RERANKER_ENABLED=true

# ── Request timeouts ──────────────────────────────────────────────────────────
# Seconds to wait for LLM response. Increase for large models on slow hardware.
REQUEST_TIMEOUT=180

# ── Authentication ────────────────────────────────────────────────────────────
# Leave CHAINLIT_AUTH_SECRET blank to disable login (local dev).
# Set to a random secret string to enable password auth in production.
CHAINLIT_AUTH_SECRET=

# Credentials — only used when CHAINLIT_AUTH_SECRET is set.
# CHANGE THESE before exposing TARA on any network.
TARA_USERNAME=tara
TARA_PASSWORD=tara

# ── Feedback database ─────────────────────────────────────────────────────────
# Path to the SQLite feedback database. Default: ./data/feedback.db
# FEEDBACK_DB_PATH=/custom/path/to/feedback.db
