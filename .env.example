# AgentForge environment variables
# Copy this file to .env and fill in values for your environment.
# All variables have defaults that work for a local Ollama + Docker Compose setup.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | groq | ollama-cloud | custom
LLM_PROVIDER=ollama

# Model name for the selected provider.
# ollama:     deepseek-r1:latest  llama3.1:8b  mistral:7b
# openai:     gpt-4o  gpt-4o-mini  gpt-3.5-turbo
# anthropic:  claude-opus-4-7  claude-sonnet-4-6  claude-haiku-4-5-20251001
# groq:       llama-3.3-70b-versatile  deepseek-r1-distill-llama-70b
LLM_MODEL=deepseek-r1:latest

# API key — leave blank for local Ollama.
LLM_API_KEY=

# Base URL — only needed for groq / ollama-cloud / custom providers.
LLM_API_BASE=

# ── Embedding model ───────────────────────────────────────────────────────────
# Must be available in Ollama. Pull with: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# ── Ollama ────────────────────────────────────────────────────────────────────
# Leave as-is for local Ollama. Inside Docker use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Weaviate vector store ─────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080

# ── AgentForge ────────────────────────────────────────────────────────────────
# Base URL for Chainlit — used to build per-agent chat links.
# Local dev: http://localhost:8080   Docker: http://chainlit:8080
CHAINLIT_URL=http://localhost:8080

# SQLite database for agent configs, URL sources, and ingest history.
# Default: ./data/agents.db
# AGENTS_DB_PATH=/custom/path/agents.db

# Root folder for uploaded knowledge files (one sub-folder per agent ID).
# Default: ./data/agent_files
# AGENT_FILES_ROOT=/custom/path/agent_files

# API key for the AgentForge builder UI. Leave blank for open dev mode.
# When set, all /api/* routes require: Authorization: Bearer <key>
FORGE_API_KEY=

# ── Chainlit auth (optional) ──────────────────────────────────────────────────
# Leave CHAINLIT_AUTH_SECRET blank to disable Chainlit login (local dev).
CHAINLIT_AUTH_SECRET=
TARA_USERNAME=tara
TARA_PASSWORD=tara

# ── TARA legacy knowledge base ────────────────────────────────────────────────
# Weaviate collection name for TARA's built-in KB (used by python ingest.py).
COLLECTION_NAME=TibcoKnowledge

# Local knowledge docs directory for python ingest.py.
KNOWLEDGE_PATH=./data/knowledge

# ── Misc ──────────────────────────────────────────────────────────────────────
# Seconds to wait for LLM response. Increase for large models on slow hardware.
REQUEST_TIMEOUT=180

# Path to the SQLite feedback database.
# FEEDBACK_DB_PATH=./data/feedback.db

# Set to false to skip cross-encoder reranking (faster, lower accuracy).
RERANKER_ENABLED=true
