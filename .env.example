# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama            # ollama | openai | anthropic | groq | ollama-cloud | custom
LLM_MODEL=deepseek-r1:latest
LLM_API_KEY=                   # required for openai / anthropic / groq / pinecone
LLM_API_BASE=                  # custom base URL (groq / ollama-cloud / custom providers)

# ── Embedding model ────────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── Vector store ───────────────────────────────────────────────────────────────
# Choose one of: weaviate | chroma | qdrant | pinecone | pgvector | activespaces
VECTOR_DB=weaviate

# Connection URL — format depends on backend (see table below):
#   weaviate     → http://localhost:8080
#   chroma       → http://localhost:8000  (or blank for embedded local storage)
#   qdrant       → http://localhost:6333  (or blank for in-memory)
#   pinecone     → https://<index>-<project>.svc.<env>.pinecone.io
#   pgvector     → postgresql://user:pass@host:5432/dbname
#   activespaces → tibcosub://hostname:port
VECTOR_DB_URL=http://localhost:8080

# API key — required for Pinecone; optional for Qdrant Cloud / ActiveSpaces
VECTOR_DB_API_KEY=

# Legacy alias for Weaviate URL (still accepted; VECTOR_DB_URL takes precedence)
WEAVIATE_URL=http://localhost:8080

# ── Knowledge base ─────────────────────────────────────────────────────────────
COLLECTION_NAME=TibcoKnowledge
KNOWLEDGE_PATH=./data/knowledge

# ── Server ─────────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=180
CHAINLIT_URL=http://localhost:8080
